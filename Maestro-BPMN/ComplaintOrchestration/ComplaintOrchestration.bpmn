    <bpmn:task id="Task_Stage_Triage" name="TRIAGE (human in app)">
      <bpmn:documentation>Stage 2 - human-only. Reviewer validates/edits the record and sets Gate=Investigation (proceed) or Gate=Closed (no complaint). No automation, so no subprocess. Advancing the Gate fires InvestigationProcess via a Data Fabric event trigger.</bpmn:documentation>
      <bpmn:incoming>Flow_Intake_Triage</bpmn:incoming>
      <bpmn:outgoing>Flow_Triage_Investigation</bpmn:outgoing>
    </bpmn:task>
