      <bpmn:sequenceFlow id="fcR" sourceRef="Activity_CapaRecordUpdated" targetRef="Gw_Adjust" />
      <bpmn:sequenceFlow id="fcAdjYes" name="Approved" sourceRef="Gw_Adjust" targetRef="T_Adjust">
