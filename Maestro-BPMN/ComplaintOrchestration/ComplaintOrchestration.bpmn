      <bpmn:sequenceFlow id="fc7" sourceRef="T_Debit" targetRef="Gw_Fin_Merge" />
      <bpmn:sequenceFlow id="fc8" sourceRef="Gw_Fin_Merge" targetRef="T_Close" />
      <bpmn:sequenceFlow id="fc9" sourceRef="T_Close" targetRef="Ev_Capa_End" />
