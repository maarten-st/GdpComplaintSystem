              </Assign>
              <Assign DisplayName="Set ErrorMessage" sap2010:WorkflowViewState.IdRef="Assign_ErrMsg">
                <Assign.To>
                  <OutArgument x:TypeArguments="x:String">[out_ErrorMessage]</OutArgument>
                </Assign.To>
                <Assign.Value>
                  <InArgument x:TypeArguments="x:String">[exception.Message]</InArgument>
                </Assign.Value>
              </Assign>
            </Sequence>
          </ActivityAction>
        </Catch>
      </TryCatch.Catches>
    </TryCatch>
  </Sequence>
</Activity>